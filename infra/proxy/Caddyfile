{$OXRM_HOST} {
  encode gzip zstd

  basicauth /* {
    {$OXRM_ADMIN_USER} {$OXRM_ADMIN_PASSWORD_HASH}
  }

  handle /api/* {
    reverse_proxy api:18181
  }

  handle /mcp {
    reverse_proxy mcp:18182
  }

  handle /mcp/* {
    reverse_proxy mcp:18182
  }

  handle {
    reverse_proxy web:18180
  }
}
