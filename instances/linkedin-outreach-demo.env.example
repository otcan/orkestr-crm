NODE_ENV=development
LOG_LEVEL=info
OXRM_BACKUP_REQUIRED=false

POSTGRES_DB=oxrm_linkedin_outreach_demo
POSTGRES_USER=oxrm_linkedin_outreach_demo
POSTGRES_PASSWORD=change-me

HOST_WEB_PORT=18320
HOST_API_PORT=18321
HOST_MCP_PORT=18322
HOST_POSTGRES_PORT=18323
HOST_REDIS_PORT=18324

OXRM_API_URL=http://127.0.0.1:18321
OXRM_MCP_URL=http://127.0.0.1:18322/mcp
CRM_API_URL=http://127.0.0.1:18321
CRM_MCP_URL=http://127.0.0.1:18322/mcp

OXRM_DEPLOY_TARGET=linkedin-outreach-demo
OXRM_DEPLOY_VERSION=local
OXRM_DEPLOY_GIT_SHA=
OXRM_DEPLOY_GIT_REF=
OXRM_DEPLOY_GITHUB_RUN_ID=
OXRM_DEPLOY_GITHUB_RUN_NUMBER=
OXRM_DEPLOYED_AT=

BACKUP_GITHUB_REPO=example-org/oxrm-linkedin-outreach-demo-backups
BACKUP_GITHUB_TOKEN=
BACKUP_GIT_AUTHOR_NAME="oXRM Backup"
BACKUP_GIT_AUTHOR_EMAIL=backups@oxrm.local
BACKUP_CRON="0 3 * * *"
BACKUP_WORKSPACE=.backups/linkedin-outreach-demo
PG_DUMP_DOCKER_CONTAINER=
PG_DUMP_DATABASE_URL=
