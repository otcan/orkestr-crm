NODE_ENV=development
LOG_LEVEL=info
OXRM_BACKUP_REQUIRED=false

POSTGRES_DB=oxrm_job_search_demo
POSTGRES_USER=oxrm_job_search_demo
POSTGRES_PASSWORD=change-me

HOST_WEB_PORT=18310
HOST_API_PORT=18311
HOST_MCP_PORT=18312

OXRM_API_URL=http://127.0.0.1:18311
OXRM_MCP_URL=http://127.0.0.1:18312/mcp
CRM_API_URL=http://127.0.0.1:18311
CRM_MCP_URL=http://127.0.0.1:18312/mcp

OXRM_DEPLOY_TARGET=job-search-demo
OXRM_DEPLOY_VERSION=local
OXRM_DEPLOY_GIT_SHA=
OXRM_DEPLOY_GIT_REF=
OXRM_DEPLOY_GITHUB_RUN_ID=
OXRM_DEPLOY_GITHUB_RUN_NUMBER=
OXRM_DEPLOYED_AT=
OXRM_WORKSPACE_MODE=job_search

BACKUP_GITHUB_REPO=example-org/oxrm-job-search-demo-backups
BACKUP_GITHUB_TOKEN=
BACKUP_GIT_AUTHOR_NAME="oXRM Backup"
BACKUP_GIT_AUTHOR_EMAIL=backups@oxrm.local
BACKUP_CRON="0 3 * * *"
BACKUP_WORKSPACE=.backups/job-search-demo
PG_DUMP_DOCKER_CONTAINER=
PG_DUMP_DATABASE_URL=
